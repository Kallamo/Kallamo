{
  "name": "kallamo",
  "version": "1.0.5-beta.1",
  "description": "A bring-your-own-key AI orchestration platform — build personas, feed them knowledge, chain them into workflows, and let them remember everything.",
  "desktopName": "Kallamo",
  "main": "src/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"electron .\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.kallamo.app",
    "productName": "Kallamo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/**/*",
      "package.json",
      "!node_modules/onnxruntime-web/**/*",
      "!node_modules/onnxruntime-node/**/*",
      "!node_modules/gpt-tokenizer/dist/**/*",
      "!node_modules/gpt-tokenizer/esm/**/*",
      "!node_modules/gpt-tokenizer/src/**/*",
      "!node_modules/gpt-tokenizer/data/cl100k_base.tiktoken",
      "!node_modules/gpt-tokenizer/data/p50k_base.tiktoken",
      "!node_modules/gpt-tokenizer/data/r50k_base.tiktoken"
    ],
    "fileAssociations": [
      {
        "ext": "klp",
        "name": "Kallamo AI Profile",
        "description": "Kallamo Portable AI Profile Package"
      },
      {
        "ext": "klw",
        "name": "Kallamo Workflow",
        "description": "Kallamo Portable Multi-Step Workflow Package"
      },
      {
        "ext": "klkb",
        "name": "Kallamo Knowledge Base",
        "description": "Kallamo Portable Knowledge Base Package"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kallamo"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "src/assets/icon.png",
      "category": "Office",
      "maintainer": "Jonathan Ferreira da Conceição <jonathanfcon@gmail.com>",
      "syncDesktopName": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Kallamo",
        "repo": "Kallamo"
      }
    ],
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "pt-BR"
    ]
  },
  "keywords": [],
  "author": "Jonathan Ferreira da Conceição <jonathanfcon@gmail.com>",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^26.15.2",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/merriweather": "^5.2.6",
    "@huggingface/transformers": "^4.2.0",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.10.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "gpt-tokenizer": "^3.4.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "unpdf": "^1.6.2"
  }
}